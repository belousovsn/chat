NODE_ENV=production
APP_PORT=8080
APP_HOST=0.0.0.0
APP_URL=https://chat.example.com
DATABASE_URL=postgres://chat:change-me@db:5432/chat
SESSION_SECRET=replace-with-long-random-secret
MAIL_FROM=noreply@chat.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-username
SMTP_PASS=replace-with-smtp-password
XMPP_ENABLED=false
XMPP_DOMAIN=xmpp.chat.example.com
XMPP_HOST=xmpp.chat.example.com
XMPP_CLIENT_PORT=5222
XMPP_FEDERATION_ENABLED=false
XMPP_FEDERATION_PORT=5269
XMPP_ADMIN_PORT=5443
XMPP_COMPOSE_PROFILE=xmpp
XMPP_ADMIN_JID=xmppadmin@xmpp.chat.example.com
XMPP_ADMIN_PASSWORD=replace-with-xmpp-admin-password
XMPP_API_BASE_URL=http://xmpp:5281/api
XMPP_API_USER=xmppapi@xmpp.chat.example.com
XMPP_API_PASS=replace-with-xmpp-api-password
XMPP_USER_PROVISIONING_ENABLED=false
XMPP_USER_PROVISIONING_STRICT=false
XMPP_ADMIN_USERS=kinzul,da_test
BACKUP_DIR=/srv/chat/backups
BACKUP_KEEP_DAYS=7
UPLOAD_DIR=/app/uploads
MAX_FILE_BYTES=20971520
MAX_IMAGE_BYTES=3145728
ASSISTANT_ENABLED=false
ASSISTANT_USERNAME=assistant
ASSISTANT_EMAIL=assistant@chat.example.com
ASSISTANT_API_BASE_URL=https://api.x.ai/v1
ASSISTANT_MODEL=grok-3
ASSISTANT_API_KEY=replace-with-grok-or-openai-api-key
RUN_SEED=false
POSTGRES_DB=chat
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me
