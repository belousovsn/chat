{
  "name": "@chat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "migrate": "node ./dist/db/runMigrations.js",
    "seed": "tsx src/db/seed.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "start": "node dist/index.js",
    "test": "tsx src/scripts/run-tests.ts"
  },
  "dependencies": {
    "@chat/shared": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.2.2",
    "nanoid": "^5.1.5",
    "nodemailer": "^6.10.1",
    "pg": "^8.14.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
