NODE_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_URL=http://localhost:8080
DATABASE_URL=postgres://chat:chat@db:5432/chat
SESSION_SECRET=change-me
MAIL_FROM=noreply@classic-chat.local
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
XMPP_ENABLED=true
XMPP_DOMAIN=localhost
XMPP_HOST=localhost
XMPP_CLIENT_PORT=5222
XMPP_FEDERATION_ENABLED=false
XMPP_FEDERATION_PORT=5269
XMPP_ADMIN_PORT=5443
XMPP_COMPOSE_PROFILE=xmpp
XMPP_ADMIN_JID=xmppadmin@localhost
XMPP_ADMIN_PASSWORD=xmpp-admin-pass
XMPP_API_BASE_URL=http://xmpp:5281/api
XMPP_API_USER=xmppapi@localhost
XMPP_API_PASS=xmpp-api-pass
